{
  "manifest_version": 3,
  "name": "Downpour",
  "version": "2.12.11",
  "description": "Downpour saves videos from any page — hover overlays on videos across the web, plus TikTok, X, and Instagram.",
  "permissions": [
    "webRequest",
    "activeTab",
    "tabs",
    "nativeMessaging"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Downpour",
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "64": "icons/icon-64.png",
      "96": "icons/icon-96.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "platforms.js",
        "page-inject.js",
        "instagram.js",
        "tiktok-extract.js",
        "social-extract.js",
        "content.js",
        "overlay.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["instagram-injected.js"],
      "matches": ["*://*.instagram.com/*"]
    },
    {
      "resources": ["tiktok-injected.js"],
      "matches": ["*://*.tiktok.com/*"]
    },
    {
      "resources": ["social-injected.js"],
      "matches": [
        "*://*.x.com/*",
        "*://*.twitter.com/*"
      ]
    },
    {
      "resources": [
        "page-fetch-injected.js",
        "youtube-capture-injected.js",
        "youtube-player-bridge-injected.js",
        "tiktok-page-capture-injected.js",
        "social-page-capture-injected.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png",
    "256": "icons/icon-256.png",
    "512": "icons/icon-512.png"
  }
}